{
  "name": "openshop-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "set \"PORT=4001\" && set \"VITE_API_BASE=http://localhost:4001\" && concurrently \"npm run server\" \"npm run dev\"",
    "dev-all": "npm run dev:all",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node --env-file=.env server/index.js",
    "start": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "emoji-picker-react": "^4.19.1",
    "express": "^4.18.2",
    "pg": "^8.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.14.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.1"
  }
}
